FROM debian:bookworm-slim

ARG APP_USER=codexmanager
ARG APP_UID=10001
ARG RELEASE_VERSION=0.0.0
ARG RELEASE_TAG=v0.0.0
ARG RELEASE_REPOSITORY=chengliang4810/Codex-Manager-Server
ARG RELEASE_BUILT_AT=unknown

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates gosu wget \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system --gid ${APP_UID} ${APP_USER} \
    && useradd --system --uid ${APP_UID} --gid ${APP_UID} --home-dir /app --create-home --shell /usr/sbin/nologin ${APP_USER} \
    && mkdir -p /data \
    && chown -R ${APP_UID}:${APP_UID} /app /data

COPY codexmanager-service /usr/local/bin/codexmanager-service
COPY codexmanager-web /usr/local/bin/codexmanager-web
COPY docker/entrypoint.sh /usr/local/bin/codexmanager-entrypoint.sh

RUN printf '{\n  "version": "%s",\n  "releaseTag": "%s",\n  "repository": "%s",\n  "builtAt": "%s"\n}\n' \
      "$RELEASE_VERSION" "$RELEASE_TAG" "$RELEASE_REPOSITORY" "$RELEASE_BUILT_AT" \
      > /app/version.json \
    && chmod +x /usr/local/bin/codexmanager-entrypoint.sh

ENV APP_USER=${APP_USER}
ENV APP_UID=${APP_UID}
ENV CODEXMANAGER_WEB_ADDR=0.0.0.0:48761
ENV CODEXMANAGER_WEB_NO_OPEN=1
ENV CODEXMANAGER_DB_PATH=/data/codexmanager.db
ENV CODEXMANAGER_RPC_TOKEN_FILE=/data/codexmanager.rpc-token

VOLUME ["/data"]
EXPOSE 48761

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://127.0.0.1:48761/__auth_status || exit 1

ENTRYPOINT ["codexmanager-entrypoint.sh"]
CMD ["codexmanager-web"]
