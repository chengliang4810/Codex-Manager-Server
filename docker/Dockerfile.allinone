FROM rust:1-bookworm AS builder

WORKDIR /src

ARG RELEASE_VERSION=0.0.0
ARG RELEASE_TAG=v0.0.0
ARG RELEASE_REPOSITORY=chengliang4810/Codex-Manager-Server
ARG RELEASE_BUILT_AT=unknown

ENV CODEXMANAGER_RELEASE_VERSION=${RELEASE_VERSION}
ENV CODEXMANAGER_RELEASE_TAG=${RELEASE_TAG}
ENV CODEXMANAGER_RELEASE_REPOSITORY=${RELEASE_REPOSITORY}
ENV CODEXMANAGER_RELEASE_BUILT_AT=${RELEASE_BUILT_AT}

COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
COPY apps/out ./apps/out

RUN cargo build --locked -p codexmanager-service --release \
    && cargo build --locked -p codexmanager-web --release --features embedded-ui

FROM debian:bookworm-slim

ARG APP_USER=codexmanager
ARG APP_UID=10001
ARG RELEASE_VERSION=0.0.0
ARG RELEASE_TAG=v0.0.0
ARG RELEASE_REPOSITORY=chengliang4810/Codex-Manager-Server
ARG RELEASE_BUILT_AT=unknown

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates gosu wget \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system --gid ${APP_UID} ${APP_USER} \
    && useradd --system --uid ${APP_UID} --gid ${APP_UID} --home-dir /app --create-home --shell /usr/sbin/nologin ${APP_USER} \
    && mkdir -p /app/bin \
    && mkdir -p /data \
    && chown -R ${APP_UID}:${APP_UID} /app /data

COPY --from=builder /src/target/release/codexmanager-service /app/bin/codexmanager-service
COPY --from=builder /src/target/release/codexmanager-web /app/bin/codexmanager-web
COPY docker/entrypoint.sh /usr/local/bin/codexmanager-entrypoint.sh

RUN printf '{\n  "version": "%s",\n  "releaseTag": "%s",\n  "repository": "%s",\n  "builtAt": "%s"\n}\n' \
      "$RELEASE_VERSION" "$RELEASE_TAG" "$RELEASE_REPOSITORY" "$RELEASE_BUILT_AT" \
      > /app/version.json \
    && chown ${APP_UID}:${APP_UID} /app/bin/codexmanager-service /app/bin/codexmanager-web \
    && chmod +x /app/bin/codexmanager-service /app/bin/codexmanager-web /usr/local/bin/codexmanager-entrypoint.sh

ENV APP_USER=${APP_USER}
ENV APP_UID=${APP_UID}
ENV PATH=/app/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ENV CODEXMANAGER_SINGLE_CONTAINER=1
ENV CODEXMANAGER_WEB_ADDR=0.0.0.0:48761
ENV CODEXMANAGER_SERVICE_ADDR=127.0.0.1:48760
ENV CODEXMANAGER_WEB_NO_SPAWN_SERVICE=1
ENV CODEXMANAGER_WEB_NO_OPEN=1
ENV CODEXMANAGER_DB_PATH=/data/codexmanager.db
ENV CODEXMANAGER_RPC_TOKEN_FILE=/data/codexmanager.rpc-token

VOLUME ["/data"]
EXPOSE 48761

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://127.0.0.1:48761/__auth_status || exit 1

ENTRYPOINT ["codexmanager-entrypoint.sh"]
CMD ["codexmanager-web"]
